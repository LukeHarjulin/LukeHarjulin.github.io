---
import profilePic from "../../profilePic.JPG";
import githubIcon from "../../github_icon.png";
import linkedinIcon from "../../linkedin_icon.png";
import codewarsIcon from "../../codewars_icon.png";
import {
	certifications,
	education,
	experience,
	impactHighlights,
	metrics,
	navItems,
	profile,
	skillGroups
} from "../data/cv";
import "../styles/global.css";

const iconByKind = {
	github: githubIcon.src,
	linkedin: linkedinIcon.src,
	codewars: codewarsIcon.src
};

const pageTitle = `${profile.name} | ${profile.role}`;
const pageDescription = `${profile.role} specialising in platform engineering, cloud automation, reusable CI/CD, and developer enablement.`;
const skillId = (title: string) =>
	`skill-${title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and").replaceAll("/", "-")}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="theme-color" content="#111417" />
		<link rel="canonical" href="https://www.lukeharjulin.com/" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.lukeharjulin.com/" />
	</head>
	<body>
		<a class="skip-link" href="#mainContent">Skip to content</a>
		<header id="headerTop">
			<div id="logoSection" aria-label="Luke Harjulin">
				<a href="#home-section" id="logoText-first" class="logoText">Luke</a>
				<a href="#home-section" id="logoAnchor" aria-label="Home"></a>

				<div id="logo" aria-hidden="true">
					<div id="topLine" class="logoComponent lines"></div>
					<div id="bottomLine" class="logoComponent lines"></div>
					<div id="L-left" class="logoComponent"></div>
					<div id="L-bottom" class="logoComponent"></div>
					<div id="H-left" class="logoComponent H"></div>
					<div id="H-middle" class="logoComponent"></div>
					<div id="H-right" class="logoComponent H"></div>
					<div id="splitter" class="logoComponent"></div>
				</div>
				<a href="#home-section" id="logoText-last" class="logoText">Harjulin</a>
			</div>

			<nav class="navMenu" aria-label="Primary navigation">
				<button class="navButton" type="button" aria-label="Open navigation" aria-controls="menuList" aria-expanded="false">
					<span id="bar1" class="menuBar"></span>
					<span id="bar2" class="menuBar"></span>
					<span id="bar3" class="menuBar"></span>
				</button>
				<ul id="menuList">
					{navItems.map((item) => (
						<li>
							<a href={item.href}>
								<span class="navItem">{item.label}</span>
							</a>
						</li>
					))}
				</ul>
			</nav>
		</header>

		<main id="mainContent">
			<section id="home-section" class="hero section-band section-band--dark">
				<div class="hero__content">
					<div class="eyebrow">{profile.role}</div>
					<h1>{profile.name}</h1>
					<p class="hero__intro">{profile.intro}</p>
					<div class="hero__actions" aria-label="Primary actions">
						<a class="button button--primary" href={profile.cv.href} download={profile.cv.filename}>{profile.cv.label}</a>
						<a class="button button--secondary" href="#experience-section">View experience</a>
						<a class="button button--secondary" href={profile.links[1].href} target="_blank" rel="noreferrer">Connect on LinkedIn</a>
					</div>
					<ul class="social-list" aria-label="Social profiles">
						{profile.links.map((link) => (
							<li>
								<a href={link.href} target="_blank" rel="noreferrer" aria-label={link.label}>
									<img src={iconByKind[link.kind]} alt="" loading="lazy" width="34" height="34" />
								</a>
							</li>
						))}
					</ul>
				</div>

				<div class="hero__media" aria-label="Profile summary">
					<img src={profilePic.src} alt="Portrait of Luke Harjulin" width="520" height="520" />
					<div class="hero__fact">
						<span>{profile.location}</span>
						<strong>Reusable cloud platforms and delivery tooling</strong>
					</div>
				</div>
			</section>

			<section class="metrics" aria-label="Career at a glance">
				{metrics.map((metric) => (
					<div class="metric">
						<strong>{metric.value}</strong>
						<span>{metric.label}</span>
					</div>
				))}
			</section>

			<section id="about-section" class="section-band">
				<div class="section-heading">
					<div class="eyebrow">Profile</div>
					<h2>Platform engineer for reusable cloud delivery.</h2>
				</div>
				<div class="profile-grid">
					<div class="summary-copy">
						{profile.summary.map((paragraph) => <p>{paragraph}</p>)}
					</div>
					<div class="credential-panel">
						<h3>Certifications</h3>
						<ul class="certification-list">
							{certifications.map((certification) => (
								<li>
									<a class="certification-item" href={certification.href} target="_blank" rel="noreferrer">
										<img src={certification.badge} alt="" loading="lazy" width="58" height="58" />
										<span>{certification.label}</span>
									</a>
								</li>
							))}
						</ul>
						<h3>Education</h3>
						<p>{education.award}<br /><span>{education.year}</span></p>
					</div>
				</div>
			</section>

			<section id="experience-section" class="section-band section-band--muted">
				<div class="section-heading">
					<div class="eyebrow">Experience</div>
					<h2>{experience.role}</h2>
					<p>{experience.company} - {experience.context}</p>
				</div>
				<div class="experience-layout">
					<p class="experience-summary">{experience.summary}</p>
					<ul class="timeline-list">
						{experience.responsibilities.map((responsibility) => <li>{responsibility}</li>)}
					</ul>
				</div>
			</section>

			<section id="impact-section" class="section-band">
				<div class="section-heading">
					<div class="eyebrow">Selected impact</div>
					<h2>Reusable platforms, cloud migration, and developer enablement.</h2>
				</div>
				<div class="impact-grid">
					{impactHighlights.map((highlight) => (
						<article class="impact-card">
							<h3>{highlight.title}</h3>
							<p>{highlight.description}</p>
							<ul class="tag-list">
								{highlight.tags.map((tag) => <li>{tag}</li>)}
							</ul>
						</article>
					))}
				</div>
			</section>

			<section id="toolkit-section" class="section-band section-band--muted">
				<div class="section-heading">
					<div class="eyebrow">Toolkit</div>
					<h2>Cloud platforms, delivery automation, and developer tooling.</h2>
				</div>
				<div class="skills-grid">
					{skillGroups.map((group) => (
						<section class="skill-card" aria-labelledby={skillId(group.title)}>
							<h3 id={skillId(group.title)}>{group.title}</h3>
							<ul>
								{group.items.map((item) => <li>{item}</li>)}
							</ul>
						</section>
					))}
				</div>
			</section>

			<section id="contact-section" class="contact-section section-band section-band--dark">
				<div>
					<div class="eyebrow">Contact</div>
					<h2>Open to senior DevOps and platform engineering conversations.</h2>
					<p>Best reached via LinkedIn for roles involving cloud migration, reusable delivery platforms, infrastructure automation, and developer enablement.</p>
				</div>
				<div class="contact-actions">
					<a class="button button--primary" href={profile.cv.href} download={profile.cv.filename}>{profile.cv.label}</a>
					<a class="button button--secondary" href={profile.links[1].href} target="_blank" rel="noreferrer">LinkedIn</a>
					<a class="button button--secondary" href={profile.links[0].href} target="_blank" rel="noreferrer">GitHub</a>
				</div>
			</section>
		</main>

		<footer>
			<span>{profile.name}</span>
			<a href="/version.json">Deployment version</a>
		</footer>

		<script src="../scripts/site.ts"></script>
	</body>
</html>
